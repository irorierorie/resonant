{
  "name": "resonant",
  "version": "3.0.0",
  "private": true,
  "description": "A local-first, self-hosted AI companion built on the Claude Agent SDK.",
  "workspaces": [
    "packages/shared",
    "packages/backend",
    "packages/frontend"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=packages/backend",
    "build": "node scripts/build.mjs",
    "build:stamp": "node scripts/write-build-id.mjs",
    "start": "npm run start --workspace=packages/backend",
    "check": "npm run check --workspaces --if-present",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=20.0.0 <25.0.0"
  },
  "license": "Apache-2.0",
  "devDependencies": {
    "vitest": "^3.0.0"
  },
  "overrides": {
    "undici": "^6.24.0",
    "cookie": "^1.0.0",
    "fast-uri": "^3.1.2",
    "hono": "^4.12.18",
    "ip-address": "^10.1.1"
  }
}
